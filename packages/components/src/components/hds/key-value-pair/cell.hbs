<div class="hds-key-value-pair__cell-above hds-key-value-pair__cell--in-row-{{@rowIndex}}">
  {{yield (hash Label=(component "hds/form/label" controlId=@cellId contextualClass="hds-key-value-pair__cell-label"))}}
  {{yield
    (hash
      HelperText=(component
        "hds/form/helper-text" controlId=this.controlId contextualClass="hds-key-value-pair__cell-helper-text"
      )
    )
  }}
</div>
<div class="hds-key-value-pair__cell-control">
  {{yield
    (hash
      SelectBase=(component "hds/form/select/base" id=this.controlId)
      TextInputBase=(component "hds/form/text-input/base" id=this.controlId)
      Generic=(component "hds/yield")
      rowIndex=@rowIndex
      rowData=@rowData
    )
  }}
</div>
<div class="hds-key-value-pair__cell-error">
  {{yield
    (hash Error=(component "hds/form/error" controlId=this.controlId contextualClass="hds-key-value-pair__cell-error"))
  }}
</div>