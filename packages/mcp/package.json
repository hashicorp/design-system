{
  "name": "@hashicorp/design-system-mcp",
  "description": "Helios Design System MCP (Model Context Protocol) server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "hds-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "node ./scripts/clean-dist.mjs",
    "prebuild": "pnpm run clean",
    "build": "tsc",
    "pretest": "pnpm run build",
    "test": "node --test \"dist/**/*.test.js\"",
    "prestart": "pnpm run build",
    "start": "concurrently --kill-others-on-fail --names \"watch,inspector\" --prefixColors auto \"pnpm dev\" \"pnpm start:watch\"",
    "start:watch": "nodemon --watch dist --ext js --delay 200ms --exec \"node ./scripts/run-inspector.mjs node ./dist/index.js\" ./dist/index.js",
    "start:prod": "node ./dist/index.js",
    "dev": "tsc --watch",
    "format": "prettier . --cache --write",
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\" --prefixColors auto",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\" --names \"fix:\" --prefixColors auto && pnpm run format",
    "lint:format": "prettier . --cache --check",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "lint:types": "tsc --noEmit",
    "prepack": "pnpm run build && node ./scripts/set-bin-permissions.mjs"
  },
  "keywords": [
    "hashicorp",
    "helios",
    "design system",
    "mcp"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hashicorp/design-system.git",
    "directory": "packages/mcp"
  },
  "license": "MPL-2.0",
  "author": "HashiCorp Design Systems <design-systems@hashicorp.com>",
  "dependencies": {
    "@hashicorp/design-system-components": "workspace:^6.0.0",
    "@hashicorp/design-system-tokens": "workspace:^5.0.0",
    "@hashicorp/flight-icons": "workspace:^5.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fast-glob": "^3.3.3",
    "github-slugger": "^2.0.0",
    "mdast-util-to-string": "^4.0.0",
    "minisearch": "^7.2.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@modelcontextprotocol/inspector": "^0.21.2",
    "@types/node": "^22.10.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.5",
    "nodemon": "^3.1.10",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.29.0"
  },
  "engines": {
    "node": ">= 24"
  }
}
