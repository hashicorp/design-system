              "cds-g100": "{carbon.themes.g100.textOnColor}"
            }
          },
          "hover": {
            "$type": "color",
            "$value": "{color.foreground.action-hover}",
            "$modes": {
              "default": "{color.foreground.action-hover}",
              "cds-g0": "{carbon.themes.white.textOnColor}",
              "cds-g10": "{carbon.themes.g10.textOnColor}",
              "cds-g90": "{carbon.themes.g90.textOnColor}",
              "cds-g100": "{carbon.themes.g100.textOnColor}"
            }
          },
          "active": {
            "$type": "color",
