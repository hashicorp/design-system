{
  "tabs": {
    "border-color": {
      "default": {
        "$type": "color",
        "$value": "transparent",
        "$modes": {
          "default": "transparent",
          "cds-g0": "{carbon.themes.white.borderSubtle01}",
          "cds-g10": "{carbon.themes.g10.borderSubtle01}",
          "cds-g90": "{carbon.themes.g90.borderSubtle01}",
          "cds-g100": "{carbon.themes.g100.borderSubtle01}"
        }
      }
    },
    "foreground-color": {
      "selected": {
        "default": {
          "$type": "color",
          "$value": "var(--token-color-foreground-action)",
          "$modes": {
            "default": "var(--token-color-foreground-action)",
            "cds-g0": "{carbon.themes.white.textPrimary}",
            "cds-g10": "{carbon.themes.g10.textPrimary}",
            "cds-g90": "{carbon.themes.g90.textPrimary}",
            "cds-g100": "{carbon.themes.g100.textPrimary}"
          }
        },
        "hover": {
          "$type": "color",
          "$value": "var(--token-color-foreground-action-hover)",
          "$modes": {
            "default": "var(--token-color-foreground-action-hover)",
            "cds-g0": "{carbon.themes.white.textPrimary}",
            "cds-g10": "{carbon.themes.g10.textPrimary}",
            "cds-g90": "{carbon.themes.g90.textPrimary}",
            "cds-g100": "{carbon.themes.g100.textPrimary}"
          }
        }
      }
    },
    "tab": {
      "height": {
        "medium": {
          "$type": "dimension",
          "$value": "36",
          "unit": "px"
        },
        "large": {
          "$type": "dimension",
          "$value": "48",
          "unit": "px"
        }
      },
      "padding": {
        "horizontal": {
          "medium": {
            "$type": "dimension",
            "$value": "12",
            "unit": "px"
          },
          "large": {
            "$type": "dimension",
            "$value": "20",
            "unit": "px"
          }
        },
        "vertical": {
          "$type": "dimension",
          "$value": "0",
          "unit": "px"
        }
      },
      "border-radius": {
        "$type": "dimension",
        "$value": "5",
        "unit": "px"
      },
      "focus-inset": {
        "$type": "dimension",
        "$value": "6",
        "unit": "px"
      },
      "gutter": {
        "$type": "dimension",
        "$value": "6",
        "unit": "px"
      }
    },
    "indicator": {
      "height": {
        "$type": "dimension",
        "$value": "3",
        "unit": "px",
        "$modes": {
          "default": "3",
          "cds-g0": "2",
          "cds-g10": "2",
          "cds-g90": "2",
          "cds-g100": "2"
        }
      },
      "transition": {
        "function": {
          "$type": "cubicBezier",
          "$value": [0.5, 1, 0.89, 1]
        },
        "duration": {
          "$type": "duration",
          "$value": "0.6",
          "unit": "s"
        }
      }
    },
    "divider": {
      "height": {
        "$type": "dimension",
        "$value": "1",
        "unit": "px"
      }
    }
  }
}
