{
  "tabs": {
    "tab": {
      "border": {
        "color": {
          "default": {
            "$type": "color",
            "$value": "transparent",
            "$modes": {
              "default": "transparent",
              "cds-g0": "{carbon.themes.white.borderSubtle00}",
              "cds-g10": "{carbon.themes.g10.borderSubtle00}",
              "cds-g90": "{carbon.themes.g90.borderSubtle00}",
              "cds-g100": "{carbon.themes.g100.borderSubtle00}"
            }
          },
          "hover": {
            "$type": "color",
            "$value": "transparent",
            "$modes": {
              "default": "transparent",
              "cds-g0": "{color.border.strong}",
              "cds-g10": "{color.border.strong}",
              "cds-g90": "{color.border.strong}",
              "cds-g100": "{color.border.strong}"
            }
          }
        },
        "radius": {
          "$type": "dimension",
          "$value": "5",
          "unit": "px"
        }
      },
      "height": {
        "medium": {
          "$type": "dimension",
          "$value": "36",
          "unit": "px",
          "$modes": {
            "default": "36",
            "cds-g0": "40",
            "cds-g10": "40",
            "cds-g90": "40",
            "cds-g100": "40"
          }
        },
        "large": {
          "$type": "dimension",
          "$value": "48",
          "unit": "px",
          "$modes": {
            "default": "48",
            "cds-g0": "48",
            "cds-g10": "48",
            "cds-g90": "48",
            "cds-g100": "48"
          }
        }
      },
      "focus": {
        "inset": {
          "$type": "dimension",
          "$value": "6",
          "unit": "px"
        }
      },
      "foreground": {
        "color": {
          "default": {
            "$type": "color",
            "$value": "{color.foreground.primary}",
            "$modes": {
              "default": "{color.foreground.primary}",
              "cds-g0": "{carbon.themes.white.textSecondary}",
              "cds-g10": "{carbon.themes.g10.textSecondary}",
              "cds-g90": "{carbon.themes.g90.textSecondary}",
              "cds-g100": "{carbon.themes.g100.textSecondary}"
            }
          },
          "hover": {
            "$type": "color",
            "$value": "{color.foreground.action-hover}",
            "$modes": {
              "default": "{color.foreground.action-hover}",
              "cds-g0": "{carbon.themes.white.textPrimary}",
              "cds-g10": "{carbon.themes.g10.textPrimary}",
              "cds-g90": "{carbon.themes.g90.textPrimary}",
              "cds-g100": "{carbon.themes.g100.textPrimary}"
            }
          }
        }
      },
      "gutter": {
        "$type": "dimension",
        "$value": "6",
        "unit": "px"
      },
      "padding": {
        "horizontal": {
          "medium": {
            "$type": "dimension",
            "$value": "12",
            "unit": "px",
            "$modes": {
              "default": "12",
              "cds-g0": "16",
              "cds-g10": "16",
              "cds-g90": "16",
              "cds-g100": "16"
            }
          },
          "large": {
            "$type": "dimension",
            "$value": "20",
            "unit": "px",
            "$modes": {
              "default": "12",
              "cds-g0": "16",
              "cds-g10": "16",
              "cds-g90": "16",
              "cds-g100": "16"
            }
          }
        },
        "vertical": {
          "$type": "dimension",
          "$value": "0",
          "unit": "px"
        }
      },
      "selected": {
        "border": {
          "color": {
            "default": {
              "$type": "color",
              "$value": "{color.foreground.action}",
              "$modes": {
                "default": "{color.foreground.action}",
                "cds-g0": "{carbon.themes.white.borderInteractive}",
                "cds-g10": "{carbon.themes.g10.borderInteractive}",
                "cds-g90": "{carbon.themes.g90.borderInteractive}",
                "cds-g100": "{carbon.themes.g100.borderInteractive}"
              }
            },
            "hover": {
              "$type": "color",
              "$value": "{color.foreground.action-hover}",
              "$modes": {
                "default": "{color.foreground.action-hover}",
                "cds-g0": "{carbon.themes.white.borderInteractive}",
                "cds-g10": "{carbon.themes.g10.borderInteractive}",
                "cds-g90": "{carbon.themes.g90.borderInteractive}",
                "cds-g100": "{carbon.themes.g100.borderInteractive}"
              }
            }
          }
        },
        "foreground": {
          "color": {
            "default": {
              "$type": "color",
              "$value": "{color.foreground.action}",
              "$modes": {
                "default": "{color.foreground.action}",
                "cds-g0": "{carbon.themes.white.textPrimary}",
                "cds-g10": "{carbon.themes.g10.textPrimary}",
                "cds-g90": "{carbon.themes.g90.textPrimary}",
                "cds-g100": "{carbon.themes.g100.textPrimary}"
              }
            },
            "hover": {
              "$type": "color",
              "$value": "{color.foreground.action-hover}",
              "$modes": {
                "default": "{color.foreground.action-hover}",
                "cds-g0": "{carbon.themes.white.textPrimary}",
                "cds-g10": "{carbon.themes.g10.textPrimary}",
                "cds-g90": "{carbon.themes.g90.textPrimary}",
                "cds-g100": "{carbon.themes.g100.textPrimary}"
              }
            }
          }
        }
      }
    },
    "indicator": {
      "height": {
        "$type": "dimension",
        "$value": "3",
        "unit": "px",
        "$modes": {
          "default": "3",
          "cds-g0": "2",
          "cds-g10": "2",
          "cds-g90": "2",
          "cds-g100": "2"
        }
      },
      "transition": {
        "function": {
          "$type": "cubicBezier",
          "$value": [0.5, 1, 0.89, 1]
        },
        "duration": {
          "$type": "duration",
          "$value": "0.6",
          "unit": "s"
        }
      }
    },
    "divider": {
      "height": {
        "$type": "dimension",
        "$value": "1",
        "unit": "px"
      }
    }
  }
}
