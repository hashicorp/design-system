      "font-size": {
        "$type": "font-size",
        "$value": "13",
        "unit": "px",
        "$modes": {
          "default": "13",
          "cds-g0": "14",
          "cds-g10": "14",
          "cds-g90": "14",
          "cds-g100": "14"
        }
      },
      "line-height": {
        "$type": "number",
        "$value": 1.2308,
        "$modes": {
          "default": 1.2308,
          "cds-g0": 1.2858,
          "cds-g10": 1.2858,
          "cds-g90": 1.2858,
          "cds-g100": 1.2858
