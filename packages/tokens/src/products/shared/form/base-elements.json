          "$value": "{typography.body-100.font-size}",
          "unit": "px",
          "$modes": {
            "default": "{typography.body-100.font-size}",
            "cds-g0": "12",
            "cds-g10": "12",
            "cds-g90": "12",
            "cds-g100": "12"
          }
        }
      },
      "icon-size": {
        "$type": "dimension",
        "$value": "14",
        "unit": "px"
