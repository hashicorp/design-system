{
  "form": {
    "foreground": {
      "color": {
        "faint": {
          "$type": "color",
          "$value": "{color.foreground.faint}",
          "$modes": {
            "default": "{color.foreground.faint}",
            "cds-g0": "{carbon.themes.white.textHelper}",
            "cds-g10": "{carbon.themes.g10.textHelper}",
            "cds-g90": "{carbon.themes.g90.textHelper}",
            "cds-g100": "{carbon.themes.g100.textHelper}"
          },
          "private": true
        },
        "strong": {
          "$type": "color",
          "$value": "{color.foreground.strong}",
          "group": "components",
          "$modes": {
            "default": "{color.foreground.strong}",
            "cds-g0": "{carbon.themes.white.textSecondary}",
            "cds-g10": "{carbon.themes.g10.textSecondary}",
            "cds-g90": "{carbon.themes.g90.textSecondary}",
            "cds-g100": "{carbon.themes.g100.textSecondary}"
          },
          "private": true
        }
      }
    },
    "character-count": {
      "foreground": {
        "color": {
          "$type": "color",
          "$value": "{form.foreground.color.faint}",
          "group": "components"
        }
      },
      "typography": {
        "font-size": {
          "$type": "font-size",
          "$value": "{typography.body-100.font-size}",
          "unit": "px",
          "$modes": {
            "default": "{typography.body-100.font-size}",
            "cds-g0": "{carbon.typography.helperText01.font-size}",
            "cds-g10": "{carbon.typography.helperText01.font-size}",
            "cds-g90": "{carbon.typography.helperText01.font-size}",
            "cds-g100": "{carbon.typography.helperText01.font-size}"
          }
        },
        "line-height": {
          "$type": "number",
          "$value": "{typography.body-100.line-height}",
          "$modes": {
            "default": "{typography.body-100.line-height}",
            "cds-g0": "{carbon.typography.helperText01.line-height}",
            "cds-g10": "{carbon.typography.helperText01.line-height}",
            "cds-g90": "{carbon.typography.helperText01.line-height}",
            "cds-g100": "{carbon.typography.helperText01.line-height}"
          },
          "comment": "The character-count line-height is the same as the helper-text as per design"
        }
      }
    },
    "label": {
      "color": {
        "$type": "color",
        "$value": "{color.foreground.strong}",
        "group": "components",
        "comment": "deprecated: use `token-form-label-foreground-color` instead",
        "deprecated": true
      },
      "foreground": {
        "color": {
          "$type": "color",
          "$value": "{form.foreground.color.strong}",
          "group": "components"
        }
      },
      "typography": {
        "font-size": {
          "$type": "font-size",
          "$value": "{typography.body-200.font-size}",
          "unit": "px",
          "$modes": {
            "default": "{typography.body-200.font-size}",
            "cds-g0": "{carbon.typography.label01.font-size}",
            "cds-g10": "{carbon.typography.label01.font-size}",
            "cds-g90": "{carbon.typography.label01.font-size}",
            "cds-g100": "{carbon.typography.label01.font-size}"
          }
        },
        "font-weight": {
          "$type": "font-weight",
          "$value": "{typography.font-weight.semibold}",
          "$modes": {
            "default": "{typography.font-weight.semibold}",
            "cds-g0": "{carbon.typography.label01.font-weight}",
            "cds-g10": "{carbon.typography.label01.font-weight}",
            "cds-g90": "{carbon.typography.label01.font-weight}",
            "cds-g100": "{carbon.typography.label01.font-weight}"
          }
        },
        "line-height": {
          "$type": "number",
          "$value": "{typography.body-200.line-height}",
          "$modes": {
            "default": "{typography.body-200.line-height}",
            "cds-g0": "{carbon.typography.label01.line-height}",
            "cds-g10": "{carbon.typography.label01.line-height}",
            "cds-g90": "{carbon.typography.label01.line-height}",
            "cds-g100": "{carbon.typography.label01.line-height}"
          }
        }
      }
    },
    "legend": {
      "color": {
        "$type": "color",
        "$value": "{form.label.color}",
        "group": "components",
        "comment": "deprecated: use `token-form-legend-foreground-color` instead",
        "deprecated": true
      },
      "foreground": {
        "color": {
          "$type": "color",
          "$value": "{form.foreground.color.strong}",
          "group": "components"
        }
      },
      "typography": {
        "font-size": {
          "$type": "font-size",
          "$value": "{typography.body-200.font-size}",
          "unit": "px",
          "$modes": {
            "default": "{typography.body-200.font-size}",
            "cds-g0": "{carbon.typography.label01.font-size}",
            "cds-g10": "{carbon.typography.label01.font-size}",
            "cds-g90": "{carbon.typography.label01.font-size}",
            "cds-g100": "{carbon.typography.label01.font-size}"
          }
        },
        "font-weight": {
          "$type": "font-weight",
          "$value": "{typography.font-weight.semibold}",
          "$modes": {
            "default": "{typography.font-weight.semibold}",
            "cds-g0": "{carbon.typography.font-weight.regular}",
            "cds-g10": "{carbon.typography.font-weight.regular}",
            "cds-g90": "{carbon.typography.font-weight.regular}",
            "cds-g100": "{carbon.typography.font-weight.regular}"
          }
        },
        "line-height": {
          "$type": "number",
          "$value": "{typography.body-200.line-height}",
          "$modes": {
            "default": "{typography.body-200.line-height}",
            "cds-g0": "{carbon.typography.label01.line-height}",
            "cds-g10": "{carbon.typography.label01.line-height}",
            "cds-g90": "{carbon.typography.label01.line-height}",
            "cds-g100": "{carbon.typography.label01.line-height}"
          }
        }
      }
    },
    "helper-text": {
      "color": {
        "$type": "color",
        "$value": "{color.foreground.faint}",
        "group": "components",
        "comment": "deprecated: use `token-form-helper-text-foreground-color` instead",
        "deprecated": true
      },
      "foreground": {
        "color": {
          "$type": "color",
          "$value": "{form.foreground.color.faint}",
          "group": "components"
        }
      },
      "typography": {
        "font-size": {
          "$type": "font-size",
          "$value": "{typography.body-100.font-size}",
          "unit": "px",
          "$modes": {
            "default": "{typography.body-100.font-size}",
            "cds-g0": "{carbon.typography.helperText01.font-size}",
            "cds-g10": "{carbon.typography.helperText01.font-size}",
            "cds-g90": "{carbon.typography.helperText01.font-size}",
            "cds-g100": "{carbon.typography.helperText01.font-size}"
          }
        },
        "line-height": {
          "$type": "number",
          "$value": "{typography.body-100.line-height}",
          "$modes": {
            "default": "{typography.body-100.line-height}",
            "cds-g0": "{carbon.typography.helperText01.line-height}",
            "cds-g10": "{carbon.typography.helperText01.line-height}",
            "cds-g90": "{carbon.typography.helperText01.line-height}",
            "cds-g100": "{carbon.typography.helperText01.line-height}"
          }
        }
      }
    },
    "indicator": {
      "optional": {
        "color": {
          "$type": "color",
          "$value": "{color.foreground.faint}",
          "group": "components",
          "comment": "deprecated: use `token-form-indicator-optional-foreground-color` instead",
          "deprecated": true
        },
        "foreground": {
          "color": {
            "$type": "color",
            "$value": "{form.foreground.color.faint}",
            "group": "components",
            "$modes": {
              "default": "{form.foreground.color.faint}",
              "cds-g0": "{form.label.foreground.color}",
              "cds-g10": "{form.label.foreground.color}",
              "cds-g90": "{form.label.foreground.color}",
              "cds-g100": "{form.label.foreground.color}"
            }
          }
        },
        "typography": {
          "font-size": {
            "$type": "font-size",
            "$value": "{typography.body-100.font-size}",
            "unit": "px",
            "$modes": {
              "default": "{typography.body-100.font-size}",
              "cds-g0": "{carbon.typography.label01.font-size}",
              "cds-g10": "{carbon.typography.label01.font-size}",
              "cds-g90": "{carbon.typography.label01.font-size}",
              "cds-g100": "{carbon.typography.label01.font-size}"
            }
          },
          "line-height": {
            "$type": "number",
            "$value": "{typography.body-100.line-height}",
            "$modes": {
              "default": "{typography.body-100.line-height}",
              "cds-g0": "{carbon.typography.label01.line-height}",
              "cds-g10": "{carbon.typography.label01.line-height}",
              "cds-g90": "{carbon.typography.label01.line-height}",
              "cds-g100": "{carbon.typography.label01.line-height}"
            }
          }
        }
      }
    },
    "error": {
      "color": {
        "$type": "color",
        "$value": "{color.palette.red-300}",
        "group": "components",
        "comment": "deprecated: use `token-form-error-foreground-color` instead",
        "deprecated": true
      },
      "foreground": {
        "color": {
          "$type": "color",
          "$value": "{color.palette.red-300}",
          "group": "components",
          "$modes": {
            "default": "{color.palette.red-300}",
            "cds-g0": "{carbon.themes.white.textError}",
            "cds-g10": "{carbon.themes.g10.textError}",
            "cds-g90": "{carbon.themes.g90.textError}",
            "cds-g100": "{carbon.themes.g100.textError}"
          }
        }
      },
      "typography": {
        "font-size": {
          "$type": "font-size",
          "$value": "{typography.body-100.font-size}",
          "unit": "px",
          "$modes": {
            "default": "{typography.body-100.font-size}",
            "cds-g0": "{carbon.typography.helperText01.font-size}",
            "cds-g10": "{carbon.typography.helperText01.font-size}",
            "cds-g90": "{carbon.typography.helperText01.font-size}",
            "cds-g100": "{carbon.typography.helperText01.font-size}"
          }
        },
        "line-height": {
          "$type": "number",
          "$value": "{typography.body-100.line-height}",
          "$modes": {
            "default": "{typography.body-100.line-height}",
            "cds-g0": "{carbon.typography.helperText01.line-height}",
            "cds-g10": "{carbon.typography.helperText01.line-height}",
            "cds-g90": "{carbon.typography.helperText01.line-height}",
            "cds-g100": "{carbon.typography.helperText01.line-height}"
          }
        }
      },
      "icon-size": {
        "$type": "dimension",
        "$value": "14",
        "unit": "px"
      }
    }
  }
}
