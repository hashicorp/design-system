{
  "form": {
    "foreground": {
      "color": {
        "faint": {
          "$type": "color",
          "$value": "{color.foreground.faint}",
          "private": true
        },
        "strong": {
          "$type": "color",
          "$value": "{color.foreground.strong}",
          "group": "components",
          "private": true
        }
      }
    },
    "character-count": {
      "foreground": {
        "color": {
          "$type": "color",
          "$value": "{form.foreground.color.faint}",
          "group": "components"
        }
      },
      "typography": {
        "font-size": {
          "$type": "font-size",
          "$value": "{typography.body-100.font-size}",
          "unit": "px"
        },
        "line-height": {
          "$type": "number",
          "$value": "{typography.body-100.line-height}",
          "comment": "The character-count line-height is the same as the helper-text as per design"
        }
      }
    },
    "label": {
      "color": {
        "$type": "color",
        "$value": "{color.foreground.strong}",
        "group": "components",
        "comment": "deprecated: use `token-form-label-foreground-color` instead",
        "deprecated": true
      },
      "foreground": {
        "color": {
          "$type": "color",
          "$value": "{form.foreground.color.strong}",
          "group": "components"
        }
      },
      "typography": {
        "font-size": {
          "$type": "font-size",
          "$value": "{typography.body-200.font-size}",
          "unit": "px"
        },
        "font-weight": {
          "$type": "font-weight",
          "$value": "{typography.font-weight.semibold}"
        },
        "line-height": {
          "$type": "number",
          "$value": "{typography.body-200.line-height}"
        }
      }
    },
    "legend": {
      "color": {
        "$type": "color",
        "$value": "{form.label.color}",
        "group": "components",
        "comment": "deprecated: use `token-form-legend-foreground-color` instead",
        "deprecated": true
      },
      "foreground": {
        "color": {
          "$type": "color",
          "$value": "{form.foreground.color.strong}",
          "group": "components"
        }
      },
      "typography": {
        "font-size": {
          "$type": "font-size",
          "$value": "{typography.body-200.font-size}",
          "unit": "px"
        },
        "font-weight": {
          "$type": "font-weight",
          "$value": "{typography.font-weight.semibold}"
        },
        "line-height": {
          "$type": "number",
          "$value": "{typography.body-200.line-height}"
        }
      }
    },
    "helper-text": {
      "color": {
        "$type": "color",
        "$value": "{color.foreground.faint}",
        "group": "components",
        "comment": "deprecated: use `token-form-helper-text-foreground-color` instead",
        "deprecated": true
      },
      "foreground": {
        "color": {
          "$type": "color",
          "$value": "{form.foreground.color.faint}",
          "group": "components"
        }
      },
      "typography": {
        "font-size": {
          "$type": "font-size",
          "$value": "{typography.body-100.font-size}",
          "unit": "px"
        },
        "line-height": {
          "$type": "number",
          "$value": "{typography.body-100.line-height}"
        }
      }
    },
    "indicator": {
      "optional": {
        "color": {
          "$type": "color",
          "$value": "{color.foreground.faint}",
          "group": "components",
          "comment": "deprecated: use `token-form-indicator-optional-foreground-color` instead",
          "deprecated": true
        },
        "foreground": {
          "color": {
            "$type": "color",
            "$value": "{form.foreground.color.faint}",
            "group": "components"
          }
        },
        "typography": {
          "font-size": {
            "$type": "font-size",
            "$value": "{typography.body-100.font-size}",
            "unit": "px"
          },
          "line-height": {
            "$type": "number",
            "$value": "{typography.body-100.line-height}"
          }
        }
      }
    },
    "error": {
      "color": {
        "$type": "color",
        "$value": "{color.palette.red-300}",
        "group": "components",
        "comment": "deprecated: use `token-form-error-foreground-color` instead",
        "deprecated": true
      },
      "foreground": {
        "color": {
          "$type": "color",
          "$value": "{color.palette.red-300}",
          "group": "components"
        }
      },
      "typography": {
        "font-size": {
          "$type": "font-size",
          "$value": "{typography.body-100.font-size}",
          "unit": "px"
        },
        "line-height": {
          "$type": "number",
          "$value": "{typography.body-100.line-height}"
        }
      },
      "icon-size": {
        "$type": "dimension",
        "$value": "14",
        "unit": "px"
      }
    }
  }
}
