{
  "form": {
    "control": {
      "padding": {
        "$type": "dimension",
        "$value": "7",
        "unit": "px",
        "$modes": {
          "default": "7",
          "cds-g0": "16",
          "cds-g10": "16",
          "cds-g90": "16",
          "cds-g100": "16"
        },
        "comments": {
          "hds": "Notice: we have to take in account the border, so it's 1px less than in Figma",
          "cds": "Notice: we set only horizontal padding"
        }
      },
      "border": {
        "radius": {
          "$type": "dimension",
          "$value": "{border.radius.small}",
          "unit": "px"
        },
        "width": {
          "$type": "dimension",
          "$value": "1",
          "unit": "px"
        }
      }
    }
  }
}
