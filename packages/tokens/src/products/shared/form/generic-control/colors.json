{
  "form": {
    "control": {
      "base": {
        "foreground": {
          "color": {
            "$type": "color",
            "$value": "{color.foreground.strong}",
            "group": "components"
          }
        },
        "surface": {
          "color": {
            "default": {
              "$type": "color",
              "$value": "{color.surface.interactive}",
              "group": "components"
            },
            "hover": {
              "$type": "color",
              "$value": "{color.surface.interactive-hover}",
              "group": "components"
            }
          }
        },
        "border": {
          "color": {
            "default": {
              "$type": "color",
              "$value": "{color.palette.neutral-400}",
              "group": "components",
              "$modes": {
                "default": "{color.palette.neutral-400}",
                "cds-g0": "{carbon.themes.white.borderStrong01}",
                "cds-g10": "{carbon.themes.g10.borderStrong01}",
                "cds-g90": "{carbon.themes.g90.borderStrong01}",
                "cds-g100": "{carbon.themes.g100.borderStrong01}"
              }
            },
            "hover": {
              "$type": "color",
              "$value": "{color.palette.neutral-500}",
              "group": "components"
            }
          }
        },
        "placeholder": {
          "foreground": {
            "color": {
              "$type": "color",
              "$value": "{color.foreground.faint}",
              "group": "components",
              "$modes": {
                "default": "{color.foreground.faint}",
                "cds-g0": "{carbon.themes.white.textPlaceholder}",
                "cds-g10": "{carbon.themes.g10.textPlaceholder}",
                "cds-g90": "{carbon.themes.g90.textPlaceholder}",
                "cds-g100": "{carbon.themes.g100.textPlaceholder}"
              }
            }
          }
        }
      },
      "checked": {
        "foreground": {
          "color": {
            "$type": "color",
            "$value": "{color.foreground.high-contrast}",
            "group": "components"
          }
        },
        "surface": {
          "color": {
            "default": {
              "$type": "color",
              "$value": "{color.palette.blue-200}",
              "group": "components"
            },
            "hover": {
              "$type": "color",
              "$value": "{color.palette.blue-300}",
              "group": "components"
            }
          }
        },
        "border": {
          "color": {
            "default": {
              "$type": "color",
              "$value": "{color.palette.blue-300}",
              "group": "components"
            },
            "hover": {
              "$type": "color",
              "$value": "{color.palette.blue-400}",
              "group": "components"
            }
          }
        }
      },
      "invalid": {
        "border": {
          "color": {
            "default": {
              "$type": "color",
              "$value": "{color.palette.red-300}",
              "group": "components",
              "$modes": {
                "default": "{color.palette.red-300}",
                "cds-g0": "{carbon.themes.white.supportError}",
                "cds-g10": "{carbon.themes.g10.supportError}",
                "cds-g90": "{carbon.themes.g90.supportError}",
                "cds-g100": "{carbon.themes.g100.supportError}",
                "comment": "TODO: 1) Carbon uses outline instead (should border stay the same color?) 2) Double-check carbon colors"
              }
            },
            "hover": {
              "$type": "color",
              "$value": "{color.palette.red-400}",
              "group": "components"
            }
          }
        }
      },
      "readonly": {
        "foreground": {
          "color": {
            "$type": "color",
            "$value": "{color.foreground.primary}",
            "group": "components"
          }
        },
        "surface": {
          "color": {
            "$type": "color",
            "$value": "{color.surface.strong}",
            "group": "components"
          }
        },
        "border": {
          "color": {
            "$type": "color",
            "$value": "{color.border.faint}",
            "group": "components"
          }
        }
      },
      "disabled": {
        "foreground": {
          "color": {
            "$type": "color",
            "$value": "{color.foreground.disabled}",
            "group": "components"
          }
        },
        "surface": {
          "color": {
            "$type": "color",
            "$value": "{color.surface.interactive-disabled}",
            "group": "components"
          }
        },
        "border": {
          "color": {
            "$type": "color",
            "$value": "{color.border.primary}",
            "group": "components"
          }
        }
      }
    }
  }
}
