{
  "dropdown": {
    "surface": {
      "color": {
        "primary": {
          "$type": "color",
          "$value": "{color.surface.primary}",
          "$modes": {
            "default": "{color.surface.primary}",
            "cds-g0": "{carbon.themes.white.layer01}",
            "cds-g10": "{carbon.themes.g10.layer01}",
            "cds-g90": "{carbon.themes.g90.layer01}",
            "cds-g100": "{carbon.themes.g100.layer01}"
          }
        }
      }
    },
    "list-item": {
      "foreground": {
        "color": {
          "action": {
            "default": {
              "$type": "color",
              "$value": "{color.foreground.primary}",
              "$modes": {
                "default": "{color.foreground.primary}",
                "cds-g0": "{carbon.themes.white.textSecondary}",
                "cds-g10": "{carbon.themes.g10.textSecondary}",
                "cds-g90": "{carbon.themes.g90.textSecondary}",
                "cds-g100": "{carbon.themes.g100.textSecondary}"
              }
            }
          }
        }
      },
      "surface": {
        "color": {
          "hover": {
            "$type": "color",
            "$value": "transparent",
            "$modes": {
              "default": "transparent",
              "cds-g0": "{carbon.themes.white.layerHover01}",
              "cds-g10": "{carbon.themes.g10.layerHover01}",
              "cds-g90": "{carbon.themes.g90.layerHover01}",
              "cds-g100": "{carbon.themes.g100.layerHover01}"
            }
          }
        }
      }
    },
    "toggle-button": {
      "padding": {
        "right": {
          "medium": {
            "$type": "dimension",
            "$value": "9",
            "unit": "px",
            "$modes": {
              "default": "9",
              "cds-g0": "12",
              "cds-g10": "12",
              "cds-g90": "12",
              "cds-g100": "12"
            }
          },
          "small": {
            "$type": "dimension",
            "$value": "6",
            "unit": "px",
            "$modes": {
              "default": "6",
              "cds-g0": "12",
              "cds-g10": "12",
              "cds-g90": "12",
              "cds-g100": "12"
            }
          }
        }
      }
    },
    "toggle-icon": {
      "gap": {
        "$type": "dimension",
        "$value": "2",
        "unit": "px",
        "$modes": {
          "default": "2",
          "cds-g0": "4",
          "cds-g10": "4",
          "cds-g90": "4",
          "cds-g100": "4"
        }
      },
      "padding": {
        "$type": "dimension",
        "$value": "1",
        "unit": "px",
        "$modes": {
          "default": "1",
          "cds-g0": "4",
          "cds-g10": "4",
          "cds-g90": "4",
          "cds-g100": "4"
        }
      }
    }
  }
}