{
  "app-header": {
    "padding": {
      "top": {
        "$type": "dimension",
        "$value": "12",
        "unit": "px",
        "$modes": {
          "default": "12",
          "cds-g0": "0",
          "cds-g10": "0",
          "cds-g90": "0",
          "cds-g100": "0"
        }
      },
      "bottom": {
        "$type": "dimension",
        "$value": "11",
        "unit": "px",
        "$modes": {
          "default": {
            "value": "11",
            "comment": "Account for 1px border at the bottom of the header"
          },
          "cds-g0": "0",
          "cds-g10": "0",
          "cds-g90": "0",
          "cds-g100": "0"
        }
      }
    },
    "border": {
      "color": {
        "$type": "color",
        "$value": "{color.palette.neutral-500}",
        "$modes": {
          "default": "{color.palette.neutral-500}",
          "cds-g0": "{carbon.themes.white.borderSubtle00}",
          "cds-g10": "{carbon.color.gray.30}",
          "cds-g90": "{carbon.color.gray.70}",
          "cds-g100": "{carbon.color.gray.80}"
        }
      }
    },
    "foreground": {
      "color": {
        "$type": "color",
        "$value": "{color.foreground.high-contrast}",
        "$modes": {
          "default": "{color.foreground.high-contrast}",
          "cds-g0": "{carbon.themes.white.textPrimary}",
          "cds-g10": "{carbon.themes.g10.textPrimary}",
          "cds-g90": "{carbon.themes.g90.textPrimary}",
          "cds-g100": "{carbon.themes.g100.textPrimary}"
        }
      }
    },
    "surface": {
      "color": {
        "$type": "color",
        "$value": "{color.palette.neutral-700}",
        "$modes": {
          "default": "{color.palette.neutral-700}",
          "cds-g0": "{color.page.primary}",
          "cds-g10": "{color.page.primary}",
          "cds-g90": "{color.page.primary}",
          "cds-g100": "{color.page.primary}"
        }
      }
    },
    "interactive": {
      "border": {
        "color": {
          "default": {
            "$type": "color",
            "$value": "{color.palette.neutral-500}",
            "$modes": {
              "default": "{color.palette.neutral-500}",
              "cds-g0": "transparent",
              "cds-g10": "transparent",
              "cds-g90": "transparent",
              "cds-g100": "transparent"
            }
          },
          "disabled": {
            "$type": "color",
            "$value": "{color.palette.neutral-400}",
            "$modes": {
              "default": "{color.palette.neutral-400}",
              "cds-g0": "transparent",
              "cds-g10": "transparent",
              "cds-g90": "transparent",
              "cds-g100": "transparent"
            }
          }
        }
      },
      "foreground": {
        "color": {
          "default": {
            "$type": "color",
            "$value": "{color.foreground.high-contrast}",
            "$modes": {
              "default": "{color.foreground.high-contrast}",
              "cds-g0": "{carbon.themes.white.textPrimary}",
              "cds-g10": "{carbon.themes.g10.textPrimary}",
              "cds-g90": "{carbon.themes.g90.textPrimary}",
              "cds-g100": "{carbon.themes.g100.textPrimary}"
            }
          },
          "disabled": {
            "$type": "color",
            "$value": "{color.foreground.disabled}",
            "$modes": {
              "default": "{color.foreground.disabled}",
              "cds-g0": "{carbon.themes.white.textDisabled}",
              "cds-g10": "{carbon.themes.g10.textDisabled}",
              "cds-g90": "{carbon.themes.g90.textDisabled}",
              "cds-g100": "{carbon.themes.g100.textDisabled}"
            }
          }
        }
      },
      "surface": {
        "color": {
          "default": {
            "$type": "color",
            "$value": "{color.palette.neutral-700}",
            "$modes": {
              "default": "{color.palette.neutral-700}",
              "cds-g0": "transparent",
              "cds-g10": "transparent",
              "cds-g90": "transparent",
              "cds-g100": "carbon.themes.g100.backgroundHover"
            }
          },
          "hover": {
            "$type": "color",
            "$value": "{color.palette.neutral-600}",
            "$modes": {
              "default": "{color.palette.neutral-600}",
              "cds-g0": "{carbon.themes.white.backgroundHover}",
              "cds-g10": "{carbon.themes.g10.backgroundHover}",
              "cds-g90": "{carbon.themes.g90.backgroundHover}",
              "cds-g100": "{carbon.themes.g100.backgroundHover}"
            }
          },
          "active": {
            "$type": "color",
            "$value": "{color.palette.neutral-500}",
            "$modes": {
              "default": "{color.palette.neutral-500}",
              "cds-g0": "{carbon.themes.white.backgroundActive}",
              "cds-g10": "{carbon.themes.g10.backgroundActive}",
              "cds-g90": "{carbon.themes.g90.backgroundActive}",
              "cds-g100": "{carbon.themes.g100.backgroundActive}"
            }
          },
          "disabled": {
            "$type": "color",
            "$value": "{color.palette.neutral-600}",
            "$modes": {
              "default": "{color.palette.neutral-600}",
              "cds-g0": "{carbon.color.gray.30}",
              "cds-g10": "{carbon.color.gray.30}",
              "cds-g90": "{carbon.color.gray.60}",
              "cds-g100": "{carbon.color.gray.70}"
            }
          }
        }
      },
      "focus": {
        "action-internal": {
          "$type": "color",
          "$value": "#bcc7fd",
          "comment": "TODO: Remove once global tokens for dark themes are implemented",
          "$modes": {
            "default": "#bcc7fd",
            "cds-g0": "{carbon.themes.white.focusInset}",
            "cds-g10": "{carbon.themes.g10.focusInset}",
            "cds-g90": "{carbon.themes.g90.focusInset}",
            "cds-g100": "{carbon.themes.g100.focusInset}"
           }
        },
        "action-external": {
          "$type": "color",
          "$value": "#0d69f2",
          "comment": "TODO: Remove once global tokens for dark themes are implemented",
          "$modes": {
            "default": "#0d69f2",
            "cds-g0": "{carbon.themes.white.focus}",
            "cds-g10": "{carbon.themes.g10.focus}",
            "cds-g90": "{carbon.themes.g90.focus}",
            "cds-g100": "{carbon.themes.g100.focus}"
          }
        }
      }
    },
    "height": {
      "$type": "dimension",
      "$value": "60",
      "unit": "px",
      "$modes": {
        "default": "60",
        "cds-g0": "48",
        "cds-g10": "48",
        "cds-g90": "48",
        "cds-g100": "48"
       }
    },
    "home-link": {
      "size": {
        "$type": "dimension",
        "$value": "36",
        "unit": "px"
      }
    },
    "logo": {
      "size": {
        "$type": "dimension",
        "$value": "28",
        "unit": "px"
      }
    },
    "actions": {
      "gap": {
        "$type": "dimension",
        "$value": "12",
        "unit": "px",
        "$modes": {
          "default": "12",
          "cds-g0": "0",
          "cds-g10": "0",
          "cds-g90": "0",
          "cds-g100": "0"
        }
      }
    }
  }
}
