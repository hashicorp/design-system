{
  "extends": "@tsconfig/ember",
  "compilerOptions": {
    "allowJs": true,
    "paths": {
      "website/tests/*": ["./tests/*"],
      "website/*": ["./app/*"],
      "*": ["./types/*"]
    },
    "types": ["ember-source/types", "@glint/ember-tsc/types"]
  },
  "include": ["app/**/*", "tests/**/*", "types/**/*", "docs/**/*"]
}
