<Hds::Form::KeyValueInputs @data={{this.exampleData}}>
  <:header as |H|>
    <H.Legend>Invite multiple users to your organization</H.Legend>
    <H.HelperText>
      Users without an organization role cannot view or edit anything inside their organization until a project-level or
      workspace-level role is assigned to them after they accept their invitation.
    </H.HelperText>
  </:header>
  <:row as |R|>
    <R.Field as |F|>
      <F.Label>
        Email address for invitee
      </F.Label>
      <F.TextInput @value={{R.rowData.email}} />
    </R.Field>
    <R.Field as |F|>
      <F.Label>
        Name of invitee
      </F.Label>
      <F.TextInput @value={{R.rowData.name}} />
    </R.Field>
    {{#if this.canDeleteRow}}
      <R.DeleteRowButton @onClick={{this.onDeleteRow}} />
    {{/if}}
  </:row>
  <:footer as |F|>
    <F.AddRowButton @text="Add user" @onClick={{this.onAddRow}} />
  </:footer>
</Hds::Form::KeyValueInputs>