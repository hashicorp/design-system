<Hds::Form as |FORM|>
  <FORM.Section>
    <Hds::Form::SuperSelect::Single::Field
      @isRequired={{true}}
      @onChange={{fn (mut this.SELECTED_OPTION)}}
      @selected={{this.SELECTED_OPTION}}
      @options={{this.OPTIONS}}
      @searchEnabled={{true}}
      as |F|
    >
      <F.Label>This is the label</F.Label>
      <F.Options>{{F.options}}</F.Options>
    </Hds::Form::SuperSelect::Single::Field>

    <Hds::Form::SuperSelect::Single::Field
      @isOptional={{true}}
      @onChange={{fn (mut this.SELECTED_OPTION)}}
      @selected={{this.SELECTED_OPTION}}
      @options={{this.OPTIONS}}
      @searchEnabled={{true}}
      as |F|
    >
      <F.Label>This is the label</F.Label>
      <F.Options>{{F.options}}</F.Options>
    </Hds::Form::SuperSelect::Single::Field>
  </FORM.Section>
</Hds::Form>